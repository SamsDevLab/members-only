<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <%- include("partials/header") %>
    <main>
      <section class="message-board">
        <h2>Message Board</h2>
       <% if (messages.length !== 0){ %>
         <% messages.forEach(message => { %>
          <div class="message-card">
            <% if (user !== undefined && user.member === true){ %>
              <h3><%= message.username %></h3>
              <h3><%= message.timestamp %></h3>
             <% } else { %>
              <h3>Become a member to view author</h3>
              <h3>Become a member to view timestamp</h3>
             <% } %>
              <h4><%= message.title %></h4>
              <p><%= message.text %></p>
            <% if (user !== undefined && user.admin === true){ %>
              <form action="/messages/delete-message" method="POST">
                <input type="hidden" name="messageId" value="<%= message.messageid %>">
                <button>Delete</button>
              </form>
            <% } %> 
          </div>
        <% }) %>
        <% } else { %>
            <p>There are no messages at this time.</p>
        <% } %> 
      </section>
      <% if (user !== undefined) { %>
        <form action="/messages/add-message" method="POST">
        <div>
          <label for="new-title">Title</label>
          <input type="text" id="new-title" name="newTitle" />
        </div>
        <div class="new-message-input">
          <label for="new-message">Message: </label>
          <textarea id="new-message" name="newMessage"></textarea>
        </div>
        <button type="submit">Submit</button>
      </form>
      <% } %>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
