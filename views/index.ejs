<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <%- include("partials/header") %>
    <main>
      <section class="message-board">
        <h2>Message Board</h2>
      </section>
      <form action="/messages/add-message" method="POST">
        <div>
          <label for="new-title">Title</label>
          <input type="text" id="new-title" name="newTitle" />
        </div>
        <div class="new-message-input">
          <label for="new-message">Message: </label>
          <textarea id="new-message" name="newMessage"></textarea>
        </div>
        <button type="submit">Submit</button>
      </form>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
