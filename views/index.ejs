<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <%- include("partials/header") %>
    <main>
      <section class="message-board">
        <h2>The Golden Anchor Gazette</h2>
       <% if (messages.length !== 0){ %>
         <% messages.forEach(message => { %>
          <div class="message-card">
            <% if (user !== undefined && user.member === true){ %>
              <div class="message-details">
                <h3><%= message.username %></h3>
                <h3><%= message.formattedTimestamp %></h3>
              </div>
             <% } else { %>
              <div class="message-details">
                <h3>Become a member to view the author and timestamp</h3>
              </div>
             <% } %>
              <h4><%= message.title %></h4>
              <p><%= message.text %></p>
            <% if (user !== undefined && user.admin === true){ %>
              <form class="delete-button-form" action="/messages/delete-message" method="POST">
                <input type="hidden" name="messageId" value="<%= message.messageid %>">
                <button class="delete-button">Delete</button>
              </form>
            <% } %> 
          </div>
        <% }) %>
        <% } else { %>
            <p>There are no messages at this time</p>
        <% } %> 
      </section>
      <% if (user !== undefined) { %>
        <form class="add-message-form" action="/messages/add-message" method="POST">
        <div class="new-message-input">
          <label for="new-title">Title</label>
          <input type="text" id="new-title" name="newTitle" />
        </div>
        <div class="new-message-input">
          <label for="new-message">Message</label>
          <textarea id="new-message" name="newMessage"></textarea>
        </div>
        <button type="submit">Post</button>
      </form>
      <% } %>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
