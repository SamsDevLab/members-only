<header>
  <h1>Boat Club Messenger</h1>
  <% if (currentUser !== undefined){ %>
    <h2>Welcome back, <%= currentUser.first_name %>!</h2>
  <% } else { %>
    <h2>Welcome!</h2>
  <% } %>
  <div>
    <a href="/auth/login">Log In</a>
    <a href="/auth/signup">Sign Up</a>
    <a href="/auth/logout">Log Out</a>
    <% if(currentUser !== undefined && currentUser.member === false){ %>
      <a href="/membership">Become a Member</a>
    <% } else if(currentUser !== undefined && currentUser.member === true){ %>
      <a href="/admin">Become an Admin</a>
    <% } %>
  </div>
</header>
