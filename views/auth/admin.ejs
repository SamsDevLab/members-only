<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head.ejs") %>
  <body>
    <%- include("../partials/header.ejs") %>
    <main>
      <% if(errMsg !== null) { %>
        <p class="login-error"><%= errMsg %></p>
      <% } %>
      <form class="account-upgrade-form" action="/admin" method="POST">
        <label for="admin-password">Enter password to upgrade to Admin account</label>
        <input type="password" id="admin-password" name="passwordAttempt" />
        <button type="submit">Submit</button>
      </form>
    </main>
    <%- include("../partials/footer.ejs") %>
  </body>
</html>
